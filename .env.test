# Test environment configuration
# This file is used during E2E tests to enable Firebase Emulator mode

# Enable Firebase Emulators (Auth + Firestore)
VITE_USE_EMULATOR=true

# Firebase config (use your actual Firebase config or test values)
# These are public values, safe to commit for testing
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# IMPORTANT: Java 21+ Required for Firebase Emulators
#
# After installing Java 21 via Homebrew, you need to add it to your PATH:
#
#   export PATH="/opt/homebrew/opt/openjdk@21/bin:$PATH"
#
# Add this line to your ~/.zshrc or ~/.bashrc to make it permanent.
#
# Verify Java 21 is active:
#   java -version  # Should show version 21
#
# Then run tests:
#   npm run test:e2e
