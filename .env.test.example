# Test Environment Configuration Template
# Copy this file to .env.test for local E2E testing
#
# USAGE:
#   cp .env.test.example .env.test
#
# NOTE: .env.test is in .gitignore to prevent accidental commits of real credentials.
# CI creates .env.test dynamically in the workflow (see .github/workflows/playwright.yml)

# Enable Firebase Emulators (Auth + Firestore)
VITE_USE_EMULATOR=true

# Firebase config - use test/dummy values for emulator mode
# These values are only used with the emulator and don't access production Firebase
VITE_FIREBASE_API_KEY=test-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=demo-test-project
VITE_FIREBASE_STORAGE_BUCKET=demo-test-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=test-app-id

# Emulator configuration (set automatically by tests, shown here for reference)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# IMPORTANT: Java 21+ Required for Firebase Emulators
#
# Install Java 21:
#   macOS: brew install openjdk@21
#   Linux: sudo apt-get install openjdk-21-jdk
#
# Add to PATH (macOS with Homebrew):
#   export PATH="/opt/homebrew/opt/openjdk@21/bin:$PATH"
#
# Add to ~/.zshrc or ~/.bashrc to make permanent, then restart terminal.
#
# Verify:
#   java -version  # Should show version 21
#
# Run tests:
#   npm run test:e2e
